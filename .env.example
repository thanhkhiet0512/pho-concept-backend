PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pho_concept
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/pho_concept_test
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Storage - MinIO (S3-compatible, self-hosted)
S3_ENDPOINT=minio.yourdomain.com
S3_PORT=your-port
S3_USE_SSL=true
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_BUCKET=pho-concept-media
S3_REGION=us-east-1
S3_PUBLIC_ENDPOINT=https://minio.yourdomain.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SENDGRID_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000
