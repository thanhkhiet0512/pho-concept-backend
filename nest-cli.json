{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "**/*.prisma",
      { "include": "i18n/**/*.json", "outDir": "dist/src", "flat": false }
    ],
    "watchAssets": true
  }
}
