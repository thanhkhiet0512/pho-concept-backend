model CateringItem {
  id                BigInt          @id @default(autoincrement()) @map("item_id")
  cateringRequestId BigInt          @map("catering_request_id")
  menuItemId        BigInt?         @map("menu_item_id")
  customName        String?         @map("custom_name") @db.VarChar(255)
  quantity          Int
  unitPrice         Decimal         @map("unit_price") @db.Decimal(10, 2)
  note              String?         @db.VarChar(500)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  cateringRequest   CateringRequest @relation(fields: [cateringRequestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  menuItem          MenuItem?       @relation(fields: [menuItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([cateringRequestId])
  @@map("catering_items")
}
