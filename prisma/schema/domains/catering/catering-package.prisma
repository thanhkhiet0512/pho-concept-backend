model CateringPackage {
  id              BigInt    @id @default(autoincrement()) @map("package_id")
  name            String    @unique @db.VarChar(255)
  descriptionI18n Json      @map("description_i18n") @db.JsonB
  minGuests       Int       @map("min_guests")
  maxGuests       Int       @map("max_guests")
  basePrice       Decimal   @map("base_price") @db.Decimal(10, 2)
  includesI18n    Json      @map("includes_i18n") @db.JsonB
  isActive        Boolean   @default(true) @map("is_active")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  requests        CateringRequest[]

  @@index([isActive, sortOrder])
  @@map("catering_packages")
}
