model BlogPost {
  id                  BigInt          @id @default(autoincrement()) @map("blog_post_id")
  slug                String          @unique @map("slug") @db.VarChar(255)
  titleI18n           Json            @map("title_i18n") @db.JsonB
  contentI18n         Json            @map("content_i18n") @db.JsonB
  excerptI18n         Json?           @map("excerpt_i18n") @db.JsonB
  metaDescriptionI18n Json?           @map("meta_description_i18n") @db.JsonB
  coverImageUrl       String?         @map("cover_image_url") @db.VarChar(500)
  galleryImageIds     Json?           @map("gallery_image_ids") @db.JsonB
  author              String?         @map("author") @db.VarChar(255)
  externalLink        String?         @map("external_link") @db.VarChar(500)
  videoUrl            String?         @map("video_url") @db.VarChar(500)
  readTime            String?         @map("read_time") @db.VarChar(50)
  views               String?         @map("views") @db.VarChar(50)
  isFeatured          Boolean         @default(false) @map("is_featured")
  status              BlogPostStatus  @default(DRAFT)
  publishedAt         DateTime?       @map("published_at")
  categoryId          BigInt?         @map("category_id")
  category            PostCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  deletedAt           DateTime?       @map("deleted_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([status])
  @@index([categoryId])
  @@index([isFeatured])
  @@index([deletedAt])
  @@map("blog_posts")
}
