model Event {
  id              BigInt      @id @default(autoincrement()) @map("event_id")
  titleI18n       Json        @map("title_i18n") @db.JsonB
  descriptionI18n Json?       @map("description_i18n") @db.JsonB
  coverImageUrl   String?     @map("cover_image_url") @db.VarChar(500)
  eventDate       DateTime    @map("event_date") @db.Date
  eventEndDate    DateTime?   @map("event_end_date") @db.Date
  eventType       EventType   @map("event_type")
  isFeatured      Boolean     @default(false) @map("is_featured")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@index([eventDate, isActive])
  @@index([isFeatured])
  @@map("events")
}
