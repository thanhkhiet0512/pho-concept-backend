model MenuItem {
  id              BigInt          @id @default(autoincrement()) @map("menu_item_id")
  categoryId      BigInt          @map("category_id")
  category        MenuCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  slug            String          @unique @map("slug") @db.VarChar(100)
  nameI18n        Json            @map("name_i18n") @db.JsonB
  descriptionI18n Json?           @map("description_i18n") @db.JsonB
  imageUrl        String?         @map("image_url") @db.VarChar(500)
  isFeatured      Boolean         @default(false) @map("is_featured")
  isActive        Boolean         @default(true) @map("is_active")
  sortOrder       Int             @default(0) @map("sort_order")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  prices          MenuItemPrice[]
  cateringItems   CateringItem[]

  @@index([categoryId])
  @@index([isActive, deletedAt])
  @@index([isFeatured])
  @@map("menu_items")
}

model MenuItemPrice {
  id         BigInt    @id @default(autoincrement()) @map("menu_item_price_id")
  menuItemId BigInt    @map("menu_item_id")
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  locationId BigInt    @map("location_id")
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sizeLabel  String?   @map("size_label") @db.VarChar(50)
  price      Decimal   @map("price") @db.Decimal(10, 2)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([menuItemId, locationId, sizeLabel])
  @@index([locationId])
  @@map("menu_item_prices")
}
