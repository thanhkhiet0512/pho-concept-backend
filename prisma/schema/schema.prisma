generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  owner
  manager
  staff
  view_only
}

model AdminUser {
  id           BigInt     @id @default(autoincrement()) @map("admin_user_id")
  email        String     @unique @map("email") @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  name         String     @map("name") @db.VarChar(255)
  role         AdminRole
  isActive     Boolean    @default(true) @map("is_active")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("admin_users")
}

model Customer {
  id           BigInt      @id @default(autoincrement()) @map("customer_id")
  email        String      @unique @map("email") @db.VarChar(255)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  name         String      @map("name") @db.VarChar(255)
  phone        String?     @map("phone") @db.VarChar(20)
  avatarUrl    String?     @map("avatar_url") @db.VarChar(500)
  isActive     Boolean     @default(true) @map("is_active")
  lastLoginAt  DateTime?   @map("last_login_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  addresses    CustomerAddress[]

  @@map("customers")
}

model CustomerAddress {
  id          BigInt    @id @default(autoincrement()) @map("customer_address_id")
  customerId  BigInt    @map("customer_id")
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label       String    @map("label") @db.VarChar(100)
  fullName    String    @map("full_name") @db.VarChar(255)
  phone       String    @map("phone") @db.VarChar(20)
  address     String    @map("address") @db.VarChar(500)
  city        String    @map("city") @db.VarChar(100)
  state       String    @map("state") @db.VarChar(100)
  zip         String    @map("zip") @db.VarChar(20)
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([customerId])
  @@map("customer_addresses")
}

model Location {
  id        BigInt   @id @default(autoincrement()) @map("location_id")
  slug      String   @unique @map("slug") @db.VarChar(100)
  name      String   @map("name") @db.VarChar(255)
  address   String   @map("address") @db.VarChar(500)
  city      String   @map("city") @db.VarChar(100)
  state     String   @map("state") @db.VarChar(100)
  zip       String   @map("zip") @db.VarChar(20)
  phone     String?  @map("phone") @db.VarChar(20)
  email     String?  @map("email") @db.VarChar(255)
  timezone  String   @default("Asia/Ho_Chi_Minh") @map("timezone") @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  hours     LocationHour[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("locations")
}

model LocationHour {
  id         BigInt   @id @default(autoincrement()) @map("location_hour_id")
  locationId BigInt   @map("location_id")
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      @map("day_of_week")
  openTime   String   @map("open_time") @db.VarChar(5)
  closeTime  String   @map("close_time") @db.VarChar(5)
  isOpen     Boolean  @default(true) @map("is_open")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([locationId, dayOfWeek])
  @@map("location_hours")
}
